{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Create C/output folder",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"if not exist \"${workspaceFolder}\\C\\output\" mkdir \"${workspaceFolder}\\C\\output\""
			],
			"problemMatcher": []
		},
		{
			"type": "cppbuild",
			"label": "build active file to C/output (g++)",
			"command": "D:\\code interpreter\\mingw64\\bin\\g++.exe",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"${file}",
				"-o",
				"${workspaceFolder}\\C\\output\\${fileBasenameNoExtension}.exe"
			],
			"options": {
				"cwd": "${workspaceFolder}\\C"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"dependsOn": [
				"Create C/output folder"
			],
			"detail": "编译器: D:\\code interpreter\\mingw64\\bin\\g++.exe"
		}
	]
}